<div class="innercredits">
  <div class="credits-header">
    <div class="sort-controls">
      <button class="sort-btn active" data-sort="featured">{% if locale == "en" %}Featured{% else %}Em Destaque{% endif %}</button>
      <button class="sort-btn" data-sort="latest">{% if locale == "en" %}Latest{% else %}Últimos{% endif %}</button>
      <button class="sort-btn" data-sort="oldest">{% if locale == "en" %}Oldest{% else %}Primeiros{% endif %}</button>
    </div>
  </div>
  
  <div class="artwork gallery-grid">
  {% for item in creditList %}
    <a href="{{ item.link }}" 
       class="grid-item am-trigger"
       data-date="{{ item.date }}" 
       data-artist="{{ item.artist }}"
       data-featured="{{ item.featured }}">
       
       <div class="cover-wrapper">
         {% image "./src/_data/" + item.image, item.artist + " - " + item.work, "150px", "", "lazy", [450] %}
         <div class="play-overlay">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#EDA40E" viewBox="0 -960 960 960"><path d="m380-300 280-180-280-180zM480-80q-83 0-156-31.5T197-197t-85.5-127T80-480t31.5-156T197-763t127-85.5T480-880t156 31.5T763-763t85.5 127T880-480t-31.5 156T763-197t-127 85.5T480-80"/></svg>
         </div>
       </div>
       <h3>{{ item.artist }}</h3>
      <h4>{{ item.work }}</h4>
      
      <p>{{ item.service }}
        <span>
          {% if locale == "en" %}
             {{ item.date }}
          {% else %}
             {{ item.date 
                | replace("January", "Janeiro")
                | replace("February", "Fevereiro")
                | replace("March", "Março")
                | replace("April", "Abril")
                | replace("May", "Maio")
                | replace("June", "Junho")
                | replace("July", "Julho")
                | replace("August", "Agosto")
                | replace("September", "Setembro")
                | replace("October", "Outubro")
                | replace("November", "Novembro")
                | replace("December", "Dezembro") 
             }}
          {% endif %}
        </span>
      </p>
    </a>
  {% endfor %}
  </div>
</div>

<div id="am-modal" class="am-modal">
  <div class="am-modal-overlay" id="am-modal-bg"></div>
  <div class="am-modal-container">
    <button class="am-modal-close" id="am-modal-close-btn">×</button>
    <div class="am-modal-content">
      <iframe id="am-iframe" 
              allow="autoplay *; encrypted-media *; fullscreen *; clipboard-write; picture-in-picture" 
              frameborder="0" 
              height="450" 
              style="width:100%;max-width:660px;overflow:hidden;background:transparent;" 
              sandbox="allow-forms allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation">
      </iframe>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

  // ==========================================================================
  // 1. BIO OVERLAY LOGIC
  // ==========================================================================
  const bioTriggers = document.querySelectorAll('.bio-trigger');
  const closeButtons = document.querySelectorAll('.close-bio');
  const overlays = document.querySelectorAll('.bio-overlay');

  // Open the corresponding overlay
  bioTriggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault(); 
      const targetId = trigger.getAttribute('data-target');
      const targetOverlay = document.getElementById(targetId);
      
      if (targetOverlay) {
        targetOverlay.classList.add('is-open');
        document.body.style.overflow = 'hidden'; 
      }
    });
  });

  // Close the overlay when clicking X
  closeButtons.forEach(button => {
    button.addEventListener('click', () => {
      overlays.forEach(overlay => overlay.classList.remove('is-open'));
      document.body.style.overflow = ''; 
    });
  });


  // ==========================================================================
  // 2. DYNAMIC IMESSAGE LOGIC
  // ==========================================================================
  const isAppleDevice = () => {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;
    if (/iPad|iPhone|iPod/.test(userAgent) && !window.MSStream) return true;
    if (/Macintosh|Mac OS X/.test(userAgent)) return true;
    return false;
  };

  // If on an Apple device, find all iMessage containers and inject the buttons
  if (isAppleDevice()) {
    const iMessageContainers = document.querySelectorAll('.imessage-container');
    const iMessageSvg = `
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" class="btn-icon">
        <path d="M12 2C6.477 2 2 6.14 2 11.25c0 2.87 1.455 5.43 3.738 7.152-.08.822-.44 2.115-1.503 3.256a.75.75 0 00.51 1.298c2.477-.042 4.496-1.134 5.577-1.921A10.74 10.74 0 0012 20.5c5.523 0 10-4.14 10-9.25S17.523 2 12 2z"/>
      </svg>
    `;

    iMessageContainers.forEach(container => {
      const user = container.getAttribute('data-user');
      const domain = container.getAttribute('data-domain');
      const label = container.getAttribute('data-label') || "Message me on iMessage";
      
      if (user && domain) {
        const fullEmail = user + "@" + domain;
        
        container.style.display = 'block'; 
        container.innerHTML = `
          <a href="sms:${fullEmail}" class="social-btn imessage-btn">
            ${iMessageSvg}
            ${label}
          </a>
        `;
      }
    });
  }


  // ==========================================================================
  // 3. CREDITS SORTING LOGIC
  // ==========================================================================
  const parseDate = (dateStr) => {
    if (!dateStr) return 0;
    const months = {
      "January": "01", "February": "02", "March": "03", "April": "04",
      "May": "05", "June": "06", "July": "07", "August": "08",
      "September": "09", "October": "10", "November": "11", "December": "12"
    };
    const parts = dateStr.split(" ");
    if (parts.length < 2) return 0;
    return parseInt(parts[1] + (months[parts[0]] || "00"));
  };

  const sections = document.querySelectorAll('.innercredits');

  sections.forEach(section => {
    const grid = section.querySelector('.gallery-grid');
    const buttons = section.querySelectorAll('.sort-btn');

    if (!grid || buttons.length === 0) return;

    const allItems = Array.from(grid.querySelectorAll('.grid-item'));

    const runSort = (sortType) => {
      let itemsToSort = [];

      allItems.forEach(item => {
        if (sortType === 'featured') {
          if (item.dataset.featured === 'true') {
            item.style.display = '';
            itemsToSort.push(item);
          } else {
            item.style.display = 'none';
          }
        } else {
          item.style.display = '';
          itemsToSort.push(item);
        }
      });

      if (sortType === 'featured') {
        itemsToSort.sort(() => Math.random() - 0.5);
      } else {
        itemsToSort.sort((a, b) => {
          const valA = parseDate(a.dataset.date);
          const valB = parseDate(b.dataset.date);
          if (sortType === 'latest') {
            if (valA !== valB) return valB - valA;
            return a.dataset.artist.localeCompare(b.dataset.artist);
          }
          if (sortType === 'oldest') {
            if (valA !== valB) return valA - valB;
            return a.dataset.artist.localeCompare(b.dataset.artist);
          }
        });
      }

      itemsToSort.forEach(item => grid.appendChild(item));
      grid.scrollTo({ left: 0, behavior: 'smooth' });
    };

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        runSort(btn.getAttribute('data-sort'));
      });
    });

    runSort('featured');
  });


  // ==========================================================================
  // 4. MEDIA MODAL LOGIC (Apple, Spotify, Bandcamp, YouTube)
  // ==========================================================================
  const modal     = document.getElementById('am-modal');
  const iframe    = document.getElementById('am-iframe');
  const closeBtn  = document.getElementById('am-modal-close-btn');
  const modalBg   = document.getElementById('am-modal-bg');
  const container = document.querySelector('.am-modal-container');
  const triggers  = document.querySelectorAll('.am-trigger');

  const getEmbedUrl = (url) => {
    try {
      const urlObj = new URL(url);
      
      // Apple Music
      if (urlObj.hostname.includes('music.apple.com')) {
        urlObj.hostname = 'embed.music.apple.com';
        return urlObj.toString();
      }
      
      // Spotify
      if (urlObj.hostname.includes('spotify.com')) {
        if (!urlObj.pathname.startsWith('/embed')) {
          urlObj.pathname = '/embed' + urlObj.pathname;
        }
        return urlObj.toString();
      }

      // YouTube (Forces privacy-enhanced mode)
      if (urlObj.hostname.includes('youtube.com') || urlObj.hostname.includes('youtu.be') || urlObj.hostname.includes('youtube-nocookie.com')) {
        let videoId = '';
        
        // Extract ID from youtu.be/ID
        if (urlObj.hostname.includes('youtu.be')) {
          videoId = urlObj.pathname.slice(1);
        } 
        // Extract ID from youtube.com/watch?v=ID
        else if (urlObj.searchParams.has('v')) {
          videoId = urlObj.searchParams.get('v');
        } 
        // Already an embed link
        else if (urlObj.pathname.includes('/embed/')) {
          return `https://www.youtube-nocookie.com${urlObj.pathname}`; 
        }

        if (videoId) {
          return `https://www.youtube-nocookie.com/embed/${videoId}`;
        }
      }
    } catch (e) {
      console.error("Invalid URL provided to embed parser.");
    }
    return url;
  };

  // Reset container position back to CSS default (bottom-right)
  const resetPosition = () => {
    if (container) {
      container.style.top    = '';
      container.style.left   = '';
      container.style.bottom = '';
      container.style.right  = '';
    }
  };

  const closeModal = () => {
    if (modal) {
      modal.classList.remove('is-open');
      iframe.src = '';
      resetPosition();
    }
  };

  triggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const originalUrl = trigger.getAttribute('href');

      if (originalUrl) {
        
        // Safety net for Bandcamp standard links
        if (originalUrl.includes('bandcamp.com') && !originalUrl.includes('EmbeddedPlayer')) {
          window.open(originalUrl, '_blank', 'noopener,noreferrer');
          return;
        }

        let optimalHeight = 450;
        
        // Detect platform to set height
        if (originalUrl.includes('music.apple.com')) {
          optimalHeight = (originalUrl.includes('?i=') || originalUrl.includes('/song/')) ? 175 : 450;
        } else if (originalUrl.includes('spotify.com')) {
          optimalHeight = originalUrl.includes('/track/') ? 152 : 352;
        } else if (originalUrl.includes('bandcamp.com/EmbeddedPlayer')) {
          optimalHeight = originalUrl.includes('track=') ? 120 : 472;
        } else if (originalUrl.includes('youtube') || originalUrl.includes('youtu.be')) {
          optimalHeight = 220; // 16:9 sweet spot
        }

        iframe.setAttribute('height', optimalHeight);
        iframe.src = getEmbedUrl(originalUrl);
        modal.classList.add('is-open');
      }
    });
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);

  // Close via overlay — mobile only
  if (modalBg) {
    modalBg.addEventListener('click', () => {
      if (window.innerWidth < 768) closeModal();
    });
  }


  // ==========================================================================
  // 5. GLOBAL ESCAPE KEY LOGIC
  // ==========================================================================
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      // Close Media Player
      if (modal && modal.classList.contains('is-open')) {
        closeModal();
      }
      // Close Bio Overlays
      overlays.forEach(overlay => overlay.classList.remove('is-open'));
      document.body.style.overflow = ''; 
    }
  });


  // ==========================================================================
  // 6. DESKTOP DRAG LOGIC (For Media Player)
  // ==========================================================================
  let isDragging = false;
  let offsetX = 0;
  let offsetY = 0;
  
  // Helper to detect touchscreens (iPads, Android tablets, phones)
  const isTouchDevice = () => window.matchMedia("(pointer: coarse)").matches;
  
  if (container) {
    // 1. Start Drag
    container.addEventListener('mousedown', (e) => {
      // Disable on small screens AND all touchscreens
      if (window.innerWidth < 768 || isTouchDevice()) return;
      if (e.target === closeBtn) return;
  
      isDragging = true;
  
      const rect = container.getBoundingClientRect();
      container.style.bottom = 'unset';
      container.style.right  = 'unset';
      container.style.top    = rect.top + 'px';
      container.style.left   = rect.left + 'px';
  
      offsetX = e.clientX - rect.left;
      offsetY = e.clientY - rect.top;
  
      iframe.style.pointerEvents = 'none';
  
      e.preventDefault();
    });
  
    // 2. Double-Click to Snap Back to Default
    container.addEventListener('dblclick', (e) => {
      // Disable on small screens AND all touchscreens
      if (window.innerWidth < 768 || isTouchDevice()) return;
      if (e.target === closeBtn) return;
  
      isDragging = false;
      if (iframe) iframe.style.pointerEvents = '';
      
      resetPosition();
    });
  }
  
  // 3. Handle the Dragging
  document.addEventListener('mousemove', (e) => {
    if (!isDragging || !container) return;
  
    let newLeft = e.clientX - offsetX;
    let newTop  = e.clientY - offsetY;
  
    const rect = container.getBoundingClientRect();
    newLeft = Math.max(0, Math.min(newLeft, window.innerWidth  - rect.width));
    newTop  = Math.max(0, Math.min(newTop,  window.innerHeight - rect.height));
  
    container.style.left = newLeft + 'px';
    container.style.top  = newTop  + 'px';
  });
  
  // 4. End Drag
  document.addEventListener('mouseup', () => {
    if (isDragging && iframe) {
      iframe.style.pointerEvents = '';
    }
    isDragging = false;
  });
});
</script>
<style>
  /* --- MUSIC MODAL / MINI-PLAYER STYLES --- */
.am-modal {
  display: none;
  position: fixed;
  z-index: 10005;
  top: 0; left: 0; width: 100%; height: 100%;
  align-items: center;
  justify-content: center;
}

.am-modal.is-open {
  display: flex;
}

/* ---------- MOBILE (default): full overlay ---------- */
.am-modal-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.8);
  cursor: pointer;
}

.am-modal-container {
  position: relative;
  width: 90%;
  max-width: 500px;
  background: rgba(25,25,25,0.98);
  border-radius: 12px;
  padding: 43px 10px 10px;
  z-index: 10006;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.am-modal-close {
  position: absolute;
  top: 2px; right: 5px;
  background: none;
  border: none;
  color: white;
  font-size: 28px;
  cursor: pointer;
  z-index: 10007;
}

.am-modal-close:hover {
  color: #fa243c;
}

.am-modal-content iframe {
  width: 100%;
  border-radius: 8px;
}

/* ---------- DESKTOP: floating bottom-right mini-player ---------- */
@media (min-width: 768px) {

  /* Collapse the modal wrapper so it doesn't block the page */
  .am-modal {
    top: unset; left: unset;
    bottom: 0; right: 0;
    width: 0; height: 0;
    pointer-events: none;
    overflow: visible;
  }

  /* Hide the darkening overlay */
  .am-modal-overlay {
    display: none;
  }

  /* 
    KEY FIX: position: fixed here so top/left set by JS
    are always relative to the viewport, not the parent.
  */
  .am-modal-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    top: unset;
    left: unset;
    width: 320px;
    max-width: 320px;
    pointer-events: all;
    cursor: grab;
    user-select: none;
    animation: slideUp 0.25s ease;
  }

  .am-modal-container:active {
    cursor: grabbing;
  }

  /* Close button keeps a normal pointer cursor */
  .am-modal-close {
    cursor: pointer;
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
}
  
</style>