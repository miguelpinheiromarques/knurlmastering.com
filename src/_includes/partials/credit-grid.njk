           </div>
         </div>
         <h3>{{ item.artist }}</h3>
        <h4>{{ item.work }}</h4>
        
        <p>{{ item.service }}
          <span>
            {% if locale == "en" %}
               {{ item.date }}
            {% else %}
               {{ item.date 
                  | replace("January", "Janeiro")
