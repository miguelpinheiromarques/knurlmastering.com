                  | replace("March", "Março")
                  | replace("April", "Abril")
                  | replace("May", "Maio")
                  | replace("June", "Junho")
                  | replace("July", "Julho")
                  | replace("August", "Agosto")
                  | replace("September", "Setembro")
                  | replace("October", "Outubro")
                  | replace("November", "Novembro")
                  | replace("December", "Dezembro") 
               }}
            {% endif %}
          </span>
        </p>
        {% if item.grammy %}
        <span class="grammy-badge" title="{{ item.grammyLabel[locale] }}" aria-label="{{ item.grammyLabel[locale] }}">
