<style>
.credits {
  margin: 0;
  padding:20px 0 0 0;
  background-color:#f0f0f0;
}
@media screen and (min-width: 768px) {
  .credits {padding:20px;}
}  
.credits .innercredits {
  background-color:#242424;
  border-top: 4px solid #EDA40E;
}

.credits h3 {
  margin: 0;
  padding: 3px 0 5px 6px;
  font-optical-sizing: auto;
  font-size: 1rem;
  white-space:nowrap;
  font-weight: 600;
}

.split-container {
  display: flex;
  flex-wrap: wrap; 
  width: 100%;
}
@media (min-width: 768px) {
  .split-col {
    width: calc(50% - 10px); 
    box-sizing: border-box;
    padding:10px 0 0 0;
    margin:0 10px 0 0;
    background-color: #202020;
  }
  .split-col:last-child {padding-left:0;margin:0 0 0 10px;}
}

.split-col h3{margin:0 0 10px 20px;padding:0;}
.split-col h3 {color:#181818}
  
@media (min-width: 768px) {
  .split-col h3{margin:0 0 10px 0;padding:0 20px;color:#fff}
}
.split-col img {
  width: 100%;
  height: 350px;
  object-fit: cover;
  display: block;
}
.split-col img.pos-right {
  object-position: right center; 
}
.split-col img.pos-left {
  object-position: left center; 
}
.full-section {
  padding: 0;
  margin: 0 auto;
}

@media (max-width: 768px) {
  .split-col {
    width: 100%;
    padding:0;
    margin:0 0 40px 0;
    border:none;
  }
}

.credits-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding:1px 5px 0 20px;
}


.credits-header a{color:#fff}
.sort-controls {
  display: flex;
  gap: 1rem;
  padding:10px 10px 7px 0;
}

@media (max-width: 768px) {
  .credits-header {padding:1px 15px 0 10px;}
  .sort-controls {
    padding:10px 10px 7px 10px;
  }
}

.sort-btn {
  background: transparent;
  border: 0;
  padding: 0;
  font-size: 0.6rem;
  font-weight: 500;
  text-transform: uppercase;
  cursor: pointer;
  color:#999;
  white-space: nowrap;
}

.sort-btn:hover {
  color: #666;
}
.bio-trigger {white-space:nowrap;}

.sort-btn.active {
    color: #EDA40E;          
    opacity: 1;                  
}

h3.creditsheader{color:#161616;margin:0 20px;padding:20px 0;border-top:3px solid #EDA40E;font-size:140%}

/* --- THE SCROLL GRID --- */

.artwork-wrapper {
  position: relative;
  width: 100%;
}

.credits .artwork {
  display: grid;
  grid-template-rows: repeat(2, min-content);
  grid-auto-flow: column;
  grid-auto-columns: 150px;
  gap: 30px 25px;

  cursor: grab; 
  overscroll-behavior: auto; 
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  overflow-x: auto;
  overflow-y: clip;    /* 1. CHANGE 'hidden' to 'clip' */
  touch-action: pan-x pan-y; /* 2. ADD this line */
  
  width: 100%;
  height: auto; 
  margin: 0;
  padding: 30px 20px; 
  
  background-color: #282828;
  color: #fff;
  
  box-shadow: inset 0px 10px 10px 0px rgba(20,20,20,0.4),inset 0px -10px 10px 0px rgba(20,20,20,0.4);
}

.credits .artwork:active {
  cursor: grabbing;
}

/* --- BOTTOM NAVIGATION BAR --- */
.credits-footer {
  display: flex;
  justify-content: flex-end; 
  gap: 0.5rem;
  /* Thin padding to pull the arrows tightly against the grid */
  padding: 4px 15px 5px 15px;
  border-bottom:4px solid #EDA40E;
  background-color:#242424;
}

@media (hover: none) and (pointer: coarse) {
  .credits-footer {justify-content: space-between;}
}

.credits-footer button svg{height:18px;width:18px;}

.grid-nav {
  background: transparent;
  color: #999;
  border: none;
  cursor: pointer;
  display: flex;
  justify-content: center;
  align-items: center;
  /* Minimal padding to keep the buttons small */
  padding: 2px;
  transition: all 0.2s ease;
  
  opacity: 0;
  visibility: hidden;
}

.grid-nav:hover {
  color: #EDA40E;
  transform: scale(1.1);
}

.grid-nav.is-visible {
  opacity: 1;
  visibility: visible;
}


.credits .artwork a {
  width: 150px;
  text-decoration: none;
  color: #fff;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  position: relative;
}

.credits .artwork img {
  width: 150px;
  height: 150px;
  object-fit: contain; 
  margin-bottom: 8px; 
  outline: 1px solid #181818;
  outline-offset: -1px;
  box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);
  transition: all .1s linear;
  display: block;
  border-radius:2px;
}

.credits .artwork a:hover img {
  outline: 2px solid rgba(237, 164, 14, 0.8);
}

.credits .artwork h3 {
  font-weight: 300;
  margin: 0;
  padding: 0;
  font-size: 0.8rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #fff;
}

.credits .artwork h4 {
  font-weight: 600;
  margin: 0;
  padding: 2px 0 0 0;
  font-size: 0.8rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #fff;
}

.credits .artwork p {
  font-size: 0.7rem;
  font-weight: 400;
  margin: 0;
  padding: 2px 0 0 0;
  color: #888;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.credits .artwork p span {
  display: block;
  font-style: normal;
  font-weight: 400;
  text-transform: uppercase;
  font-size: 0.5rem;
  margin: 4px 0 0 0;
}
  /* --- MUSIC MODAL / MINI-PLAYER STYLES --- */
.am-modal {
  display: none;
  position: fixed;
  z-index: 10005;
  top: 0; left: 0; width: 100%; height: 100%;
  align-items: center;
  justify-content: center;
}

.am-modal.is-open {
  display: flex;
}

.am-modal-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.8);
  cursor: pointer;
}

.am-modal-container {
  position: relative;
  width: 90%;
  max-width: 500px;
  background: rgba(25,25,25,0.98);
  border-radius: 12px;
  padding: 43px 10px 10px;
  z-index: 10006;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  overflow: hidden; /* This clips the "white" triangles */
  line-height: 0;
}

.am-modal-close {
  position: absolute;
  top: 2px; right: 5px;
  background: none;
  border: none;
  color: white;
  font-size: 28px;
  cursor: pointer;
  z-index: 10007;
}

.am-modal-close:hover {
  color: #fa243c;
}

.am-modal-content iframe {
  width: 100%;
  border-radius: 12px;
  background-color: transparent; 
  overscroll-behavior: none;
}

@media (prefers-color-scheme: dark) {
  .am-modal-content iframe{border:1px solid #282828}
  .am-modal-container {background: rgba(28,28,30,0.98);}
}

@media (min-width: 768px) {
  .am-modal {
    top: unset; left: unset;
    bottom: 0; right: 0;
    width: 0; height: 0;
    pointer-events: none;
    overflow: visible;
  }

  .am-modal-overlay {
    display: none;
  }

  .am-modal-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    top: unset;
    left: unset;
    width: 320px;
    max-width: 320px;
    pointer-events: all;
    cursor: grab;
    user-select: none;
    animation: slideUp 0.25s ease;
  }

  .am-modal-container:active {
    cursor: grabbing;
  }

  .am-modal-close {
    cursor: pointer;
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
}

/* --- PLAY ICON HOVER EFFECT --- */
.cover-wrapper {
  position: relative;
  display: block;
  width: 150px;
  height: 150px;
  margin-bottom: 8px;
}

.credits .artwork img {
  margin-bottom: 0;
  width: 100%;
  height: 100%;
}

/* --- LATIN GRAMMY BADGE --- */
.grammy-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 19px;
  height: 19px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid #EDA40E;
  border-radius: 50%;
  z-index: 3;
  pointer-events: none;
}

.grammy-badge svg {
  width: 11px;
  height: 11px;
  color: #EDA40E;
}

.play-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.6); 
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0; 
  transition: opacity 0.2s ease;
  border-radius: 2px;
  pointer-events: none; 
}

.play-overlay svg {
  width: 48px;
  height: 48px;
  color: #EDA40E; 
  filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.1)); 
  opacity:0;
  transition: opacity 0.5s ease;
}

.credits .artwork a:hover .play-overlay, .credits .artwork a:hover .play-overlay svg{
  opacity: 1;
}

@media (prefers-color-scheme: dark) {
  .credits {
    border-color: #282828;
    color: #f0f0f0
  }
  
  .credits {background-color: #191919;}

  .credits h2,
  .contact h2,
  .credits h3{
    color: #f0f0f0
  }

 h3.creditsheader{color:#f0f0f0;}
}  
</style>
<div class="innercredits">
  <div class="credits-header">
    <div class="sort-controls">
      <button class="sort-btn active" data-sort="featured">{% if locale == "en" %}Featured{% else %}Em Destaque{% endif %}</button>
      <button class="sort-btn" data-sort="latest">{% if locale == "en" %}Latest{% else %}Últimos{% endif %}</button>
      <button class="sort-btn" data-sort="oldest">{% if locale == "en" %}Oldest{% else %}Primeiros{% endif %}</button>
    </div>
  </div>
  
  <div class="artwork-wrapper">
    <div class="artwork gallery-grid">
    {% for item in creditList %}
      {% set imgAlt = item.alt[locale] if item.alt else item.artist + " - " + item.work %}
