  -webkit-overflow-scrolling: touch;
}

/* Custom Scrollbar System */
.legal-content::-webkit-scrollbar {
  width: 4px;
}
.legal-content::-webkit-scrollbar-track {
  background: transparent;
}
.legal-content::-webkit-scrollbar-thumb {
