<style>
/* --- Plain text Trigger Styling --- */
.legal-trigger-text.overlay-trigger {
  display: inline;          /* Ensures it sits flat within a text paragraph */
  background: none;        /* Strips any global button background colors */
  border: none;            /* Strips any global button borders */
  padding: 0;              /* Strips any global button padding */
  margin: 0;               /* Strips any global button margins */
  border-radius: 0;        /* Strips any global rounded corners */
  font-size: inherit;      /* Dynamically matches the parent paragraph font size */
  font-family: inherit;    /* Dynamically matches the parent paragraph font family */
  font-weight: inherit;    /* Dynamically matches the parent paragraph font weight */
  color: inherit;          /* Dynamically inherits your paragraph text color */
  text-decoration: none;   /* Keeps it looking clean by default */
  cursor: pointer;         /* Keeps the pointer hand so users know it's clickable */
  box-shadow: none;        /* Strips any global button shadows */
  transition: text-decoration 0.2s ease;
}

.legal-trigger-text.overlay-trigger:hover,
.legal-trigger-text.overlay-trigger:focus {
  text-decoration: underline; /* The only visual feedback on hover */
  background: none;          /* Keeps background clean on hover */
  color: inherit;            /* Prevents text color from changing shifts */
}
/* --- Plain text Trigger Styling --- */
.legal-trigger-text {
  cursor: pointer;
  text-decoration: none;
  color: inherit; /* Dynamically inherits your paragraph text color */
  transition: text-decoration 0.2s ease;
}

.legal-trigger-text:hover {
  text-decoration: underline;
}

/* --- Container & Content Scroller --- */
.legal-container {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 90px 24px 40px 24px;
}

.legal-content {
  width: 100%;
  max-width: 700px; 
  max-height: calc(100vh - 150px);
  overflow-y: auto;
  padding-right: 16px;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

/* Custom scrollbar to keep layout premium and minimal */
.legal-content::-webkit-scrollbar {
  width: 4px;
}
.legal-content::-webkit-scrollbar-track {
  background: transparent;
}
.legal-content::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.15);
  border-radius: 2px;
}

@media (prefers-color-scheme: dark) {
  .legal-content::-webkit-scrollbar-thumb {
	background: rgba(255, 255, 255, 0.15);
  }
}

/* --- Typography System --- */
.legal-section {
  margin-bottom: 35px;
}

.legal-section h2 {
  font-size: 1.25rem;
  font-weight: 500;
  letter-spacing: 0.03em;
  margin-bottom: 14px;
  color: #1a1a1a;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  padding-bottom: 6px;
}

.legal-section p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #4a4a4a;
  margin-bottom: 12px;
}

.legal-section strong {
  color: #000;
}

/* --- Dark Mode Adjustments --- */
@media (prefers-color-scheme: dark) {
  .legal-section h2 {
	color: #f5f5f5;
	border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .legal-section p {
	color: #a0a0a0;
  }
  .legal-section strong {
	color: #fff;
  }
}

/* --- PT Compliance Elements --- */
.portuguese-legal-badges {
  margin-top: 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.legal-badge-link {
  display: inline-block;
  width: fit-content;
  transition: opacity 0.2s ease;
}

.legal-badge-link:hover {
  opacity: 0.8;
}

.legal-badge-img {
  max-width: 160px;
  height: auto;
  display: block;
}

.small-print {
  font-size: 0.75rem !important;
  line-height: 1.4 !important;
  opacity: 0.65;
}
</style>