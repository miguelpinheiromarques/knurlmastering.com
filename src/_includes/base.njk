<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>

  <link rel="preload" href="/css/style.css?v={% version %}" as="style">

  <link rel="canonical" href="https://knurlmastering.com{{ page.url }}" />
  
  {% if locale == "pt" %}
    <link rel="alternate" hreflang="pt" href="https://knurlmastering.com{{ page.url }}" />
    <link rel="alternate" hreflang="en" href="https://knurlmastering.com{{ page.url | replace('/pt/', '/en/') }}" />
  {% else %}
    <link rel="alternate" hreflang="pt" href="https://knurlmastering.com{{ page.url | replace('/en/', '/pt/') }}" />
    <link rel="alternate" hreflang="en" href="https://knurlmastering.com{{ page.url }}" />
  {% endif %}
  <link rel="alternate" hreflang="x-default" href="https://knurlmastering.com/" />

  
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <meta name="author" content="Knurl Mastering">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <meta name="google" content="notranslate">  
  
  <meta name="theme-color" content="#383838" /> 
  
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-title" content="Knurl" />
  
  <meta property="og:url" content="{{ site_url }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="https://knurlmastering.com/knurlmastering-og.jpg">
  <meta property="og:image:width" content="1024">
  <meta property="og:image:height" content="683">
  <meta name="twitter:card" content="summary_large_image">
  <meta property="twitter:domain" content="{{ site_url }}">
  <meta property="twitter:url" content="{{ site_url }}">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="https://knurlmastering.com/knurlmastering.jpg">
  
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AudioProductionStudio",
    "name": "Knurl Mastering",
    "image": "https://knurlmastering.com/knurlmastering-og.jpg",
    "description": "{{ 'Knurl Mastering is a music mastering studio founded by engineers Miguel Pinheiro Marques and Clara Araújo, driven by a deep respect for records, sonics, and the pursuit of high fidelity.' if locale != 'pt' else 'Knurl Mastering é um estúdio de masterização fundado por Miguel Pinheiro Marques e Clara Araújo.' }}",
    "url": "https://knurlmastering.com/{{ locale }}/",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Baltar",
      "addressRegion": "Porto",
      "postalCode": "4585",
      "addressCountry": "PT"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 41.1931,
      "longitude": -8.3861
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday"
      ],
      "opens": "10:00",
      "closes": "19:00"
    },
    "knowsAbout": [
      "Audio Mastering",
      "Stereo Mastering",
      "Stem Mastering",
      "Vinyl Pre-Mastering",
      "Audio Post-Production"
    ],
    "sameAs": [
      "https://www.instagram.com/knurlmastering",
      "https://www.threads.net/@knurlmastering",
      "https://www.facebook.com/profile.php?id=61576228155764"
    ]
  }
  </script>  

  <link rel="stylesheet" href="/css/style.css?v={% version %}">  
</head>

<body>  
  
  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script>
    (async function() {
      // Find the first matching model context API interface (production or testing)
      const modelContext = window.navigator.modelContext || window.navigator.modelContextTesting;
      if (!modelContext || typeof modelContext.provideContext !== 'function') {
        return;
      }
      
      try {
        await modelContext.provideContext({
          tools: [
            {
              name: "getStudioInfo",
              description: "Retrieve Knurl Mastering biography, studio philosophy, engineers profile, location, and legal details.",
              inputSchema: { type: "object", properties: {} },
              execute: async () => {
                return {
                  studio: "Knurl Mastering",
                  engineers: ["Miguel Pinheiro Marques", "Clara Araújo"],
                  location: "Baltar, Porto, Portugal",
                  biography: "Our name is inspired by the crisp, crosshatched knurls formed through metalworking on a lathe and the organic, unpredictable beauty of wood grain in a natural knurl. Balance between technical accuracy and aesthetic sensibility guides our practice.",
                  legal: {
                    nif: "220270694",
                    operator: "Miguel Pinheiro Marques (Empresário em Nome Individual)"
                  },
                  email: "info@knurlmastering.com"
                };
              }
            },
            {
              name: "getServices",
              description: "Retrieve available mastering services, formats, deliverables list, turnaround time guidelines, and pricing rates.",
              inputSchema: { type: "object", properties: {} },
              execute: async () => {
                return {
                  services: [
                    { name: "Stereo Mastering", description: "High-end final stereo audio processing optimized for streaming, CD, and high-res digital distribution." },
                    { name: "Stem Mastering", description: "Advanced mastering working from separated instrument groups (stems) to maximize mix balance." },
                    { name: "Vinyl Pre-Mastering", description: "Specialized dynamic preparation respecting physical disc-cutting constraints." }
                  ],
                  pricing: "€60 to €95 per track ($70 to $110 USD) depending on the track length and choice of engineer.",
                  deliverables: [
                    "High-resolution 96kHz/24bit digital masters",
                    "Video-optimized 48kHz/24bit masters",
                    "CD manufacturing-ready DDP images",
                    "Tailored Vinyl pre-masters"
                  ],
                  turnaround: "First version within 2-3 business days. Revisions are completed within 1-2 business days."
                };
              }
            },
            {
              name: "submitInquiry",
              description: "Prepare and pre-fill the website contact form with the user's name, email, and inquiry message so they can easily send a booking or quotation request.",
              inputSchema: {
                type: "object",
                properties: {
                  name: { type: "string", description: "The user's or artist's name" },
                  email: { type: "string", description: "Contact email address" },
                  message: { type: "string", description: "Details of the mastering project (e.g. number of tracks, mix type, deadlines)" }
                },
                required: ["name", "email", "message"]
              },
              execute: async (args) => {
                const nameInput = document.getElementById("name");
                const emailInput = document.getElementById("email");
                const messageInput = document.getElementById("message");
                
                if (nameInput) nameInput.value = args.name;
                if (emailInput) emailInput.value = args.email;
                if (messageInput) messageInput.value = args.message;
                
                // Proactively scroll the form into view
                const contactSection = document.getElementById("contact");
                if (contactSection) {
                  contactSection.scrollIntoView({ behavior: "smooth" });
                }
                
                return {
                  success: true,
                  status: "Form pre-filled and scrolled into view. Please instruct the user to verify the fields and click 'Send message'."
                };
              }
            }
          ]
        });
        console.log("WebMCP tools registered successfully.");
      } catch (err) {
        console.error("Failed to register WebMCP context tools:", err);
      }
    })();
  </script>

</body>
</html>
